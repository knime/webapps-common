  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Section",
        "label": "Create ad hoc execution",
        "elements": [
          {
            "type": "Control",
            "scope": "#/properties/version",
            "options": {
              "format": "dropdownWithDatedOptions"
            }
          },
          {
            "type": "Control",
            "scope": "#/properties/executionContext",
            "options": {
              "format": "executionContextDropdown"
            }
          },
          {
            "type": "Section",
            "label": "Email notifications",
            "description": "Setup email notifications of the workflow execution.",
            "elements": [
              {
                "type": "Control",
                "scope": "#/properties/enableWorkflowActions"
              },
              {
                "rule": {
                  "effect": "SHOW",
                  "condition": {
                    "scope": "#/properties/enableWorkflowActions",
                    "type": "LEAF",
                    "expectedValue": true
                  }
                },
                "elements": [
                  {
                    "type": "SimpleArrayLayout",
                    "scope": "#/properties/workflowActions",
                    "options": {
                      "addButtonText": "Add more",
                      "showSortButtons": false,
                      "detail": {
                        "horizontalLayout": {
                          "type": "HorizontalLayout",
                          "elements": [
                            {
                              "type": "Control",
                              "scope": "#/properties/email"
                            },
                            {
                              "type": "Control",
                              "scope": "#/properties/condition",
                              "options": {
                                "format": "dropdown"
                              }
                            }
                          ]
                        }
                      }
                    }
                  },
                  {
                    "type": "Control",
                    "scope": "#/properties/appendNodeMessages"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "data": {
    "version": "2",
    "executionContext": "4835366a-1fed-43ae-89ee-b126ce835a5a",
    "enableWorkflowActions": true,
    "appendNodeMessages": true,
    "workflowActions": [
      {
        "email": "support@knime.com",
        "condition": "onFailure"
      },
      {
        "email": "info@knime.com",
        "condition": "onSuccess"
      }
    ]
  }
}
