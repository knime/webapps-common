      "enableWorkflowActions": {
        "title": "Enable email notifications",
        "type": "boolean",
        "default": false
      },
      "workflowActions": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "email": {
              "title": "Email address",
              "type": "string",
              "placeholder": "email@knime.com"
            },
            "condition": {
              "title": "Condition",
              "oneOf": [
                {
                  "title": "Success",
                  "const": "onSuccess"
                },
                {
                  "title": "Failure",
                  "const": "onFailure"
                },
                {
                  "title": "Success or failure",
                  "const": "onSuccessOrFailure"
                }
              ],
              "default": "onFailure"
            }
          }
        }
      },
