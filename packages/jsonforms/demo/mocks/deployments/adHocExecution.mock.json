{
  "schema": {
    "type": "object",
    "properties": {
      "deploymentName": {
        "title": "Deployment name",
        "type": "string"
      },
      "version": {
        "title": "Version",
        "default": "2"
      },
      "executionContext": {
        "title": "Execution context",
        "default": "4835366a-1fed-43ae-89ee-b126ce835a5a",
        "description": "Running execution contexts are ready to use. Execution contexts using the auto start and stop function might require time to load."
      },
      "enableWorkflowActions": {
        "title": "Enable email notifications",
        "type": "boolean",
        "default": false
      },
      "workflowActions": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "email": {
              "title": "Email address",
              "type": "string",
              "placeholder": "email@knime.com"
            },
            "condition": {
              "title": "Condition",
              "oneOf": [
                {
                  "title": "Success",
                  "const": "onSuccess"
                },
                {
                  "title": "Failure",
                  "const": "onFailure"
                },
                {
                  "title": "Success or failure",
                  "const": "onSuccessOrFailure"
                }
              ],
              "default": "onFailure"
            }
          }
        }
      },
      "appendNodeMessages": {
        "title": "Append workflow messages",
        "type": "boolean",
        "default": false
      },
      "configuration": {
        "type": "object",
        "properties": {}
      }
    }
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Section",
        "label": "Create ad hoc execution",
