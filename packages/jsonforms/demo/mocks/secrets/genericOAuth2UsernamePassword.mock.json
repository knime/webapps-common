{
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "",
        "description": "The unique name of the secret which is also displayed in the <a href=\"https://hub.knime.com/knime/extensions/com.knime.features.hub.nodes/latest/com.knime.hub.nodes.secretstore.SecretRetrieverNodeFactory/\" target=\"_blank\">Secrets Retriever node.</a>"
      },
      "description": {
        "title": "Description",
        "type": "string",
        "default": ""
      },
      "configSchemaGroup": {
        "title": "Type of secret",
        "oneOf": [
          {
            "const": "box",
            "title": "Box"
          },
          {
            "const": "credentials",
            "title": "Credentials"
          },
          {
            "const": "databricks",
            "title": "Databricks"
          },
          {
            "const": "file",
            "title": "File"
          },
          {
            "const": "generic_oauth2",
            "title": "Generic OAuth2"
          },
          {
            "const": "google",
            "title": "Google"
          },
          {
            "const": "microsoft",
            "title": "Microsoft"
          },
          {
            "const": "salesforce",
            "title": "Salesforce"
          }
        ]
      },
      "configSchema": {
        "title": "Authentication type",
        "oneOf": [
          {
            "const": "oauth2_auth_code",
            "title": "Interactive"
          },
          {
            "const": "oauth2_client_credentials",
            "title": "Client credentials"
          },
          {
            "const": "oauth2_password",
            "title": "Username/Password"
          }
        ]
      },
      "config": {
        "type": "object",
        "default": {},
        "properties": {
          "tokenUrl": {
            "title": "Token endpoint URL",
            "type": "string",
            "description": "The token endpoint URL of the OAuth2 service."
          },
          "username": {
            "title": "Username",
            "type": "string"
          },
          "password": {
            "title": "Password",
            "type": "object",
            "password": {
              "type": "string"
            }
          },
          "appType": {
            "title": "Type",
            "oneOf": [
              {
                "const": "public",
                "title": "Public"
              },
              {
                "const": "confidential",
                "title": "Confidential"
              }
            ],
            "default": "public",
            "description": "Whether a public or confidential application flow should be used. A confidential application requires a secret."
          },
          "clientId": {
            "title": "ID",
            "type": "string",
            "description": "The client/application ID. In some services this is called API key."
          },
          "clientSecret": {
            "title": "Secret",
            "type": "string",
            "description": "Specifies the client/application secret to use."
          },
          "scopes": {
            "title": "Custom Scopes",
            "type": "array",
            "items": {
              "type": "string",
              "default": ""
            },
            "default": []
          },
          "tokenRequestMethod": {
            "title": "Token endpoint request method",
            "oneOf": [
              {
                "const": "POST",
                "title": "POST"
              },
              {
                "const": "GET",
                "title": "GET"
              }
            ],
            "default": "POST",
            "description": "HTTP method to use when requesting the access token from the token endpoint."
          },
          "clientAuthType": {
            "title": "Client/App authentication method",
            "oneOf": [
              {
                "const": "HTTP_BASIC_AUTH",
                "title": "HTTP Basic Auth"
              },
              {
                "const": "REQUEST_BODY",
                "title": "Request Body"
              }
            ],
            "default": "HTTP_BASIC_AUTH",
            "description": "How to transfer client/application ID and secret to the service endpoints. HTTP Basic Auth is the most common method, but some services expect these values to be part of the form-encoded request body."
          }
        }
      }
    }
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Section",
        "label": "Secret basics",
        "elements": [
          {
            "type": "Control",
            "scope": "#/properties/name"
          },
          {
            "type": "Control",
            "scope": "#/properties/description"
          }
        ]
      },
      {
        "type": "Section",
        "label": "Secret type",
        "elements": [
          {
            "type": "Control",
            "scope": "#/properties/configSchemaGroup",
            "options": {
              "format": "dropdown",
              "placeholder": ""
            }
          },
          {
            "type": "Control",
            "scope": "#/properties/configSchema",
            "options": {
              "format": "dropdown",
              "placeholder": ""
            }
          }
        ]
      },
      {
        "type": "Section",
        "label": "Endpoints configuration",
        "elements": [
          {
            "type": "Control",
            "scope": "#/properties/config/properties/tokenUrl"
          }
        ]
      },
      {
        "type": "Section",
        "label": "User login",
        "elements": [
          {
            "type": "Control",
            "scope": "#/properties/config/properties/username"
          },
          {
            "type": "Control",
            "scope": "#/properties/config/properties/password"
          }
        ]
      },
      {
        "type": "Section",
        "label": "Client/App configuration",
        "elements": [
          {
            "type": "Control",
            "scope": "#/properties/config/properties/appType",
            "options": {
              "format": "valueSwitch"
            }
          },
          {
            "type": "Control",
            "scope": "#/properties/config/properties/clientId",
            "rule": {
              "effect": "SHOW",
              "condition": {
                "type": "OR",
                "conditions": [
                  {
                    "scope": "#/properties/config/properties/appType",
                    "type": "LEAF",
                    "expectedValue": "public"
                  },
                  {
                    "scope": "#/properties/config/properties/appType",
                    "type": "LEAF",
                    "expectedValue": "confidential"
                  }
                ]
              }
            }
          },
          {
            "type": "Control",
            "scope": "#/properties/config/properties/clientSecret",
            "rule": {
              "effect": "SHOW",
              "condition": {
                "scope": "#/properties/config/properties/appType",
                "type": "LEAF",
                "expectedValue": "confidential"
              }
            }
          }
        ]
      },
      {
        "type": "Section",
        "label": "Scopes of access",
        "elements": [
          {
            "type": "SimpleArrayLayout",
            "scope": "#/properties/config/properties/scopes",
            "options": {
              "addButtonText": "Add scope",
              "showSortButtons": false,
              "hideControlHeader": true,
              "detail": {
                "horizontalLayout": {
                  "type": "HorizontalLayout",
                  "elements": [
                    {
                      "type": "Control",
                      "scope": "#scopes",
                      "options": {
                        "hideControlHeader": true
                      }
                    }
                  ]
                }
              }
            }
          }
        ]
      },
      {
        "type": "VerticalLayout",
        "elements": [
          {
            "type": "SettingsSubPanelLayout",
            "label": "Advanced settings",
            "options": {
              "backButtonLabel": "Back"
            },
            "elements": [
              {
                "type": "Section",
                "label": "Token endpoint settings",
                "elements": [
                  {
                    "type": "Control",
                    "scope": "#/properties/config/properties/tokenRequestMethod",
                    "options": {
                      "format": "valueSwitch"
                    }
                  },
                  {
                    "type": "Control",
                    "scope": "#/properties/config/properties/clientAuthType",
                    "options": {
                      "format": "valueSwitch"
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "data": {
    "name": "My Generic OAuth2 Secret",
    "description": "Username/password OAuth2 credentials for the internal API.",
    "configSchemaGroup": "generic_oauth2",
    "configSchema": "oauth2_password",
    "config": {
      "tokenUrl": "https://auth.example.com/oauth2/token",
      "username": "api-user@example.com",
      "password": "*****************************",
      "appType": "confidential",
      "clientId": "my-client-id",
      "clientSecret": "*****************************",
      "scopes": ["read:data", "write:data"],
      "tokenRequestMethod": "POST",
      "clientAuthType": "HTTP_BASIC_AUTH"
    }
  }
}
