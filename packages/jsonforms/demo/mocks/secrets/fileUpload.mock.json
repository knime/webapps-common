{
  "schema": {
    "type": "object",
    "properties": {
      "file": {
        "type": "array"
      },
      "multipleFiles": {
        "type": "array"
      }
    }
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Section",
        "label": "Single File upload",
        "elements": [
          {
            "type": "Control",
            "scope": "#/properties/file",
            "options": {
              "format": "fileUpload",
              "hideControlHeader": true
            }
          }
        ]
      },
      {
        "type": "Section",
        "label": "Multiple File upload",
        "elements": [
          {
            "type": "Control",
            "scope": "#/properties/multipleFiles",
            "options": {
              "format": "fileUpload",
              "multiple": true,
              "hideControlHeader": true
            }
          }
        ]
      }
    ]
  },
  "data": {}
}
