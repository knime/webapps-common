{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["vite-env.d.ts", "**/*.ts", "**/*.tsx", "**/*.vue"],
  "exclude": ["node_modules", "**/__tests__/*"],
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2024", "ESNext.Collection", "DOM"],
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "baseUrl": ".",
    "allowJs": true,
    "noEmit": true
  }
}
